# Bundle-local venv (bootstrap from AGENTS.md)
.venv/

# Robot assets. piper_arm/ and allegro_right/ ship with the bundle as
# example inputs; everything else under robots/ (other user-populated
# inputs, generated combined-model folders) is ignored.
robots/*
!robots/piper_arm/
!robots/allegro_right/

# Python
__pycache__/
*.pyc

# MuJoCo
MUJOCO_LOG.TXT
MJMODEL.TXT
